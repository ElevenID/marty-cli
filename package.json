{
  "name": "@elevenid/marty-cli",
  "version": "0.1.0",
  "description": "Marty CLI — command-line client for the Marty Identity Platform",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "marty": "./bin/marty.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/marty.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "marty",
    "elevenid",
    "identity",
    "verifiable-credentials",
    "cli"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElevenID/marty-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@elevenid/marty-api-core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "vitest": "^1.3.0"
  }
}
